{{- $pages := slice -}}
{{- range .Site.RegularPages -}}
  {{- if and (not .Draft) (or (eq .Type "tallers") (eq .Type "blog")) -}}
    {{- $pages = $pages | append . -}}
  {{- end -}}
{{- end -}}
[
{{- range $i, $p := $pages -}}
{{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "lead": {{ with $p.Params.lead }}{{ . | jsonify }}{{ else }}{{ $p.Description | jsonify }}{{ end }},
    "url": {{ $p.RelPermalink | jsonify }},
    "type": {{ $p.Type | jsonify }}
  }
{{- end }}
]
